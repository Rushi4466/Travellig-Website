<!DOCTYPE html>
<html>
<head>
  <title>RT SkyRoutes</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: url("/images/bg.jpg") no-repeat center center/cover;
      color: white;
    }

    /* overlay */
    body::before {
      content: "";
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.5);
      z-index: -1;
    }

    /* NAVBAR */
    nav {
      display: flex;
      align-items: center;
      padding: 10px 30px;
      background: rgba(0,0,0,0.6);
    }

    /* LOGO SIZE INCREASED */
    .logo img {
      height: 90px;
    }

    /* TAGLINE WHITE */
    .tagline {
      flex: 1;
      text-align: center;
      font-size: 30px;
      font-weight: bold;
      letter-spacing: 1px;
      color: white;
      text-shadow: 2px 2px 10px black;
    }

    /* MENU RIGHT */
    .menu {
      margin-left: auto;
    }

    nav a {
      margin: 10px;
      color: white;
      text-decoration: none;
      font-weight: bold;
    }

    nav a:hover {
      color: #00d4ff;
    }

    h1 {
      text-align: center;
      margin-top: 20px;
      font-size: 45px;
      text-shadow: 2px 2px 10px black;
    }

    p {
      text-align: center;
      margin-bottom: 20px;
      font-size: 18px;
    }

    /* BUTTON */
    .btn {
      display: block;
      margin: 20px auto;
      padding: 12px 25px;
      border: none;
      border-radius: 25px;
      background: #00d4ff;
      color: black;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
    }

    .btn:hover {
      background: white;
      transform: scale(1.05);
    }

    /* DESTINATIONS */
    .container {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
    }

    .card {
      background: rgba(255,255,255,0.9);
      color: black;
      margin: 15px;
      padding: 15px;
      width: 250px;
      border-radius: 15px;
      backdrop-filter: blur(8px);
      box-shadow: 0 4px 15px rgba(0,0,0,0.5);
      transition: transform 0.3s;
    }

    .card:hover {
      transform: translateY(-10px);
    }

    .card img {
      width: 100%;
      height: 160px;
      object-fit: cover;
      border-radius: 10px;
    }

    /* CONTACT */
    .contact {
      text-align: center;
      padding: 30px;
      background: rgba(0,0,0,0.6);
      margin-top: 40px;
    }
  </style>
</head>

<body>

<!-- NAVBAR -->
<nav>
  <div class="logo">
    <img src="/images/logo.png">
  </div>

  <div class="tagline">
    ✈️ Your Journey Begins Here
  </div>

  <div class="menu">
    <a href="#">Home</a>
    <a href="#destinations">Destinations</a>
    <a href="#contact">Contact</a>
  </div>
</nav>

<!-- TITLE -->
<h1>🌍 RT SkyRoutes</h1>
<p>Explore Nature • Discover Beauty • Travel the World</p>

<!-- EXPLORE BUTTON -->
<button class="btn" onclick="document.getElementById('destinations').scrollIntoView({behavior:'smooth'})">
  Explore Now
</button>

<!-- DESTINATIONS -->
<div class="container" id="destinations">
  <% destinations.forEach(place => { %>
    <div class="card">
      <img src="<%= place.image %>" alt="">
      <h2><%= place.name %></h2>
      <p><%= place.description %></p>
    </div>
  <% }) %>
</div>

<!-- CONTACT -->
<div class="contact" id="contact">
  <h2>Contact Us</h2>
  <p>📞 Phone: 8806293031</p>
  <p>📧 Email: rtskyroutes@gmail.com</p>
</div>

</body>
</html>